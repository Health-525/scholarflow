# ScholarFlow 环境变量配置
# 复制此文件为 .env.local 并填入你的值

# GitHub Personal Access Token（必需）
# 权限要求：repo（私有仓库需勾选）
# 创建地址：https://github.com/settings/tokens
# ⚠️ 不要使用 NEXT_PUBLIC_ 前缀，避免 token 暴露到客户端
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub 仓库名（可选，默认使用 Health-525 仓库）
# NEXT_PUBLIC_GH_REPO_CONTENT=your-username/your-content-repo
# NEXT_PUBLIC_GH_REPO_EXECUTION=your-username/your-execution-repo

# Ollama 服务地址（可选，默认 http://localhost:11434）
# OLLAMA_HOST=http://localhost:11434
