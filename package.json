{
  "name": "scholarflow",
  "version": "1.3.0",
  "private": true,
  "description": "ScholarFlow — 统一学习管理前端",
  "repository": {
    "type": "git",
    "url": "https://github.com/Health-525/scholarflow"
  },
  "bugs": {
    "url": "https://github.com/Health-525/scholarflow/issues"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm test",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "electron:dev": "concurrently \"next dev\" \"electron .\"",
    "electron:hot:win": "set ELECTRON_DEV=1 && concurrently \"next dev\" \"electron .\"",
    "electron:hot:nix": "ELECTRON_DEV=1 concurrently \"next dev\" \"electron .\"",
    "electron:build": "next build && node electron/postbuild.js && electron-builder --win",
    "electron:build:portable": "next build && node electron/postbuild.js && electron-builder --win portable",
    "electron:build:installer": "next build && node electron/postbuild.js && electron-builder --win nsis",
    "mobile:build": "node scripts/mobile-build.js",
    "mobile:sync": "npx cap sync android",
    "mobile:open": "npx cap open android",
    "mobile:dev": "set BUILD_TARGET=mobile&& next dev"
  },
  "build": {
    "appId": "com.health525.scholarflow",
    "productName": "ScholarFlow",
    "copyright": "Copyright © 2026 Health-525",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "asarUnpack": [
      ".next/standalone/**/*",
      "public/**/*"
    ],
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      "public/**/*",
      "package.json",
      "!**/*.map"
    ],
    "win": {
      "icon": "public/icons/logo.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ScholarFlow"
    },
    "portable": {
      "artifactName": "ScholarFlow-${version}-portable.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "Health-525",
      "repo": "scholarflow",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@tanstack/react-query": "^5.101.0",
    "active-win": "^9.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.4.3",
    "dompurify": "^3.1.6",
    "electron-updater": "^6.8.9",
    "fuse.js": "^7.4.1",
    "hastscript": "^9.0.1",
    "lucide-react": "^1.17.0",
    "next": "^16.2.9",
    "next-pwa": "^5.6.0",
    "ogl": "^1.0.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "rehype-stringify": "^10.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "unified": "^11.0.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "astral-regex": "^2.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^8",
    "eslint-config-next": "^15.0.0",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^3.22.0",
    "jsdom": "^29.1.1",
    "msw": "^2.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5",
    "vitest": "^2.0.0",
    "wait-on": "^9.0.10"
  }
}
